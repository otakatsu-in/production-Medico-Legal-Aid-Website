# Supabase PostgreSQL connection string (for Drizzle ORM)
DATABASE_URL="postgres://postgres:[YOUR-PASSWORD]@[YOUR-SUPABASE-HOST]:5432/postgres"

# Supabase Client Credentials (optional if only using Server Actions, but good to have)
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Zoho SMTP Mail Configuration (for Nodemailer)
ZOHO_EMAIL="hello@medicolegalaid.com"
ZOHO_APP_PASSWORD="your-zoho-app-password" # Generate this from Zoho Account -> Security -> App Passwords

# Notification Email Recipient (where form submissions will be sent, e.g. Dr's email)
NOTIFICATION_RECIPIENT="recipient@medicolegalaid.com"

